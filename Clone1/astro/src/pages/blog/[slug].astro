---
// Individual blog post — structure lifted verbatim from the Cedar blog-post
// template (breadcrumb → byline → title/subtitle → hero → rich text → CTA).
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const publishedISO = d.date.toISOString().slice(0, 10);
const modifiedISO = (d.dateModified ?? d.date).toISOString().slice(0, 10);
const postURL = `https://prismaclad.com/blog/${post.id}/`;

const postSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: d.title,
    description: d.description,
    image: new URL(d.image, 'https://prismaclad.com').href,
    datePublished: publishedISO,
    dateModified: modifiedISO,
    url: postURL,
    author: { '@type': 'Organization', name: 'Prismaclad', url: 'https://prismaclad.com' },
    publisher: { '@type': 'Organization', name: 'Prismaclad', url: 'https://prismaclad.com' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://prismaclad.com/blog/' },
      { '@type': 'ListItem', position: 2, name: d.title, item: postURL },
    ],
  },
]);
---
<Base
  title={`${d.title} | Prismaclad`}
  description={d.description}
  ogImage={d.image}
  ogType="article"
  articlePublishedTime={publishedISO}
  articleModifiedTime={modifiedISO}
  schema={postSchema}
  wfPage="6a0efa92672ea8b3cf5dd4d5"
>
  <section animate="section" class="section">
    <div class="w-layout-blockcontainer container is-blog w-container">
      <div class="grid is-blog">
        <div class="content_group is-center">
          <div class="content_group is-small">
            <div animate="item" class="breadcrumb_component">
              <a href="/blog/" class="breadcrumb-link w-inline-block"><div>Blog</div></a>
              <div class="breadcrumb-divider w-embed"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M6 3L11 8L6 13" stroke="CurrentColor" stroke-width="1.5"></path>
</svg></div>
              <a href="/blog/" aria-label="Link to Category" class="breadcrumb-link w-inline-block"><div>{d.category}</div></a>
            </div>
            <div class="blog-post_author-wrapper">
              <div animate="item" class="blog-post_author-text">
                <a href="#" class="body-sm">Prismaclad</a>
                <div class="blog_meta-divider"></div>
                <div class="blog_read-time"><div class="body-sm">{d.readTime}</div><div class="body-sm">min read</div></div>
              </div>
            </div>
          </div>
          <div class="spacer-md"></div>
          <div class="content_group">
            <h1 animate="item" class="display-md">{d.title}</h1>
            <p animate="item" class="text-color-subtle">{d.subtitle}</p>
          </div>
        </div>
        <div class="spacer-3xl"></div>
        <div class="blog_image-wrapper"><img animate="item" loading="lazy" alt={d.imageAlt} src={d.image} class="_w-h-100 fit-cover" /></div>
        <div class="spacer-3xl"></div>
        <div animate="item" class="text-rich-text w-richtext"><Content /></div>
      </div>
    </div>
  </section>
  <Cta />
</Base>
